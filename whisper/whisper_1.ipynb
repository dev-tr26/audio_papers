        "def normalize_text(text: str) -> str:\n",
        "    \"\"\"Minimal normalization — keep Gujarati Unicode intact.\"\"\"\n",
        "    text = text.strip()\n",
        "    # Remove double spaces\n",
        "    import re\n",
        "    text = re.sub(r\"\\s+\", \" \", text)\n",
        "    return text"
      ],
