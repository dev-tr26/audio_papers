        "    provider=\"CPUExecutionProvider\",\n",
        ")\n",
        "ort_model.save_pretrained(str(ONNX_DIR))\n",
        "processor.save_pretrained(str(ONNX_DIR))\n",
        "print(f\"ONNX model saved to: {ONNX_DIR}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "jNQQ0kCA6tPM"
      },
      "outputs": [],
      "source": [
        "onnx_pipe = hf_pipeline(\n",
        "    \"automatic-speech-recognition\",\n",
        "    model=ort_model,\n",
        "    tokenizer=tokenizer,\n",
        "    feature_extractor=feature_extractor,\n",
        ")\n",
        "sample_audio = raw[\"test\"][0][\"audio\"]\n",
        "onnx_out = onnx_pipe({\"sampling_rate\": sample_audio[\"sampling_rate\"],\n",
        "                        \"raw\": sample_audio[\"array\"]})\n",
        "print(\"ONNX test output:\", onnx_out[\"text\"])\n",
        "print(\"Reference        :\", normalize_text(raw[\"test\"][0].get(text_col, \"\")))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "U020kz0z60o1"
      },
      "outputs": [],
      "source": [
        "import zipfile\n",
        "import shutil\n",
        "from google.colab import files as colab_files"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "Q3XqMscw60la"
      },
      "outputs": [],
      "source": [
        "def zip_and_download(source_dir: str, zip_name: str):\n",
        "    \"\"\"Zip a directory and trigger a browser download in Colab.\"\"\"\n",
        "    zip_path = f\"/content/{zip_name}\"\n",
        "    print(f\"Zipping {source_dir} → {zip_path} …\")\n",
        "    with zipfile.ZipFile(zip_path, \"w\", compression=zipfile.ZIP_DEFLATED) as zf:\n",
        "        for fpath in Path(source_dir).rglob(\"*\"):\n",
        "            if fpath.is_file():\n",
        "                zf.write(fpath, arcname=fpath.relative_to(source_dir))\n",
        "    size_mb = os.path.getsize(zip_path) / 1e6\n",
        "    print(f\"Archive size: {size_mb:.1f} MB\")\n",
        "    colab_files.download(zip_path)\n",
        "    print(f\"Download triggered for: {zip_name}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "UCSxn58q60i9"
      },
      "outputs": [],
      "source": [
        "print(\"\\n=== Option B: LoRA adapter only ===\")\n",
        "zip_and_download(hp.output_dir, \"whisper_small_gu_lora_adapter.zip\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "cKg6sR1160gX"
      },
      "outputs": [],
      "source": [
        "print(\"\\n=== Option C: ONNX model ===\")\n",
        "zip_and_download(hp.onnx_dir, \"whisper_small_gu_onnx.zip\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "OPOwCaa160d5"
      },
      "outputs": [],
      "source": [
        "print(\"\\n=== Option D: Raw PyTorch checkpoint (.pt) ===\")\n",
        "colab_files.download(str(BEST_MODEL_DIR / \"checkpoint.pt\"))\n",
        "print(\"Download triggered for: checkpoint.pt\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "J6AV-cnvTMM6"
      },
      "outputs": [],
      "source": [
        "artifact = wandb.Artifact(\"whisper-small-gu-lora\", type=\"model\")\n",
        "artifact.add_dir(hp.output_dir)\n",
        "run.log_artifact(artifact)\n",
        "wandb.finish()\n",
        "print(\"W&B run finished. All artifacts logged.\")"
      ]
