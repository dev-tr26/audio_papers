        "    axes[1].set_title(\"Validation WER\", fontweight=\"bold\")\n",
        "    axes[1].set_xlabel(\"Steps\"); axes[1].set_ylabel(\"WER (lower = better)\")\n",
        "    axes[1].grid(alpha=0.3)\n",
